# Copy to .env and fill in. Never commit .env.

# --- Portfolio config ---
# Comma-separated tickers (defaults live in code if unset)
SENTINEL_TICKERS=AAPL,MSFT,JPM,XOM,JNJ,PG,NVDA,CAT,NEE,WMT
SENTINEL_START_DATE=2018-01-01

# --- FRED (free key: https://fred.stlouisfed.org/docs/api/api_key.html) ---
FRED_API_KEY=

# --- SEC EDGAR requires a descriptive User-Agent (name + email) ---
SEC_EDGAR_USER_AGENT=Sentinel research your-name your-email@example.com

# --- LLM agent (optional; app falls back to a templated memo if unset) ---
ANTHROPIC_API_KEY=
SENTINEL_LLM_MODEL=claude-opus-4-8
